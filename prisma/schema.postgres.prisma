generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  passwordHash       String
  role               String   @default("TECHNICIAN")
  avatarUrl          String?
  firstName          String
  lastName           String
  employeeId         String   @unique
  technicianLevel    String   @default("L1")
  isActive           Boolean  @default(true)
  mustChangePassword Boolean  @default(true)
  failedLoginAttempts Int      @default(0)
  lockedUntil        DateTime?
  lastLoginAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  sessions           Session[]
  workLogs           WorkLog[]
  scheduleEvents     ScheduleEvent[] @relation("ScheduleEventTechnician")
  createdScheduleEvents ScheduleEvent[] @relation("ScheduleEventCreator")

  @@index([role])
  @@index([isActive])
}

model Session {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  userId     String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  targetType  String
  targetId    String?
  metadata    String?
  createdAt   DateTime @default(now())

  @@index([actorUserId])
  @@index([action])
  @@index([createdAt])
}

model AppConfig {
  id               String   @id
  ateraApiKey      String?
  ateraAccountId   String?
  ateraCompanyName String?
  ateraHomepageUrl String?
  ateraLocation    String?
  ateraPlan        String?
  setupCompletedAt DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model WorkLog {
  id               String   @id @default(cuid())
  userId           String
  ticketId         Int
  ticketTitle      String
  entryType        String
  hoursWorked      Float
  noteText         String?
  ateraCommentSync String   @default("synced")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([ticketId, createdAt])
  @@index([entryType])
}

model ScheduleEvent {
  id               String   @id @default(cuid())
  technicianUserId String
  createdByUserId  String
  eventType        String
  startDate        DateTime
  endDate          DateTime
  title            String?
  notes            String?
  ticketId         Int?
  ticketTitle      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  technician       User     @relation("ScheduleEventTechnician", fields: [technicianUserId], references: [id], onDelete: Cascade)
  createdByUser    User     @relation("ScheduleEventCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  scheduleEventTickets ScheduleEventTicket[]

  @@index([technicianUserId, startDate])
  @@index([startDate, endDate])
  @@index([eventType])
}

model ScheduleEventTicket {
  id              String   @id @default(cuid())
  scheduleEventId String
  ticketId        Int
  ticketTitle     String?
  createdAt       DateTime @default(now())
  scheduleEvent   ScheduleEvent @relation(fields: [scheduleEventId], references: [id], onDelete: Cascade)

  @@unique([scheduleEventId, ticketId])
  @@index([scheduleEventId])
  @@index([ticketId])
}

# Optional overrides for Docker runs.
# Base app-only startup works without this file.
# Create .env only when you want to change defaults.

# App port published to the host
APP_PORT=4217

# Change this for any real deployment.
# The image has a low-friction fallback only for quick first runs.
APP_CONFIG_ENCRYPTION_KEY=replace_with_a_long_random_secret

# Cookie security: false for direct HTTP, true behind HTTPS/Caddy.
AUTH_COOKIE_SECURE=false

# Database mode
DATABASE_PROVIDER=sqlite
SQLITE_DATABASE_URL=file:./dev.db
POSTGRES_DATABASE_URL=postgresql://ticketera:ticketera_local_password@localhost:5432/ticketera?schema=public

# Optional Atera overrides
ATERA_API_KEY=
ATERA_API_BASE=https://app.atera.com/api/v3
ATERA_TECHNICIAN_ID=

# Optional Caddy overrides
APP_DOMAIN=localhost
TLS_EMAIL=

# Optional image selection (prod/simple Docker Hub flows)
APP_IMAGE_REPO=brionispoptart/ticketera
APP_IMAGE_TAG=latest

# Optional runtime tuning
AUTH_SESSION_TTL_HOURS=12
AUTH_MAX_FAILED_LOGIN_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15

# Copy to .env.local (recommended) or .env
# Required for encrypting Atera API keys that are stored through first-run setup or the admin settings page.
APP_CONFIG_ENCRYPTION_KEY=replace_with_a_long_random_secret

# Optional: if omitted, the first-run setup flow will collect and store the Atera API key in the app database.
ATERA_API_KEY=

# Optional override if Atera changes hosts in the future
ATERA_API_BASE=https://app.atera.com/api/v3

# Standalone app port for the default app-only Docker compose.
APP_PORT=3000

# Optional Caddy reverse proxy settings.
# Use a real DNS name in production, e.g. ticketera.example.com
APP_DOMAIN=localhost

# Optional email used by Caddy/Let's Encrypt for certificate management.
TLS_EMAIL=

# Container image repository used by docker-compose.prod.yml
APP_IMAGE_REPO=brionispoptart/ticketera

# Container image tag used by docker-compose.prod.yml
APP_IMAGE_TAG=latest

# Optional fallback technician for creating internal comments if a ticket has no assigned tech.
ATERA_TECHNICIAN_ID=

# Database selection
# Supported values: sqlite, postgresql
DATABASE_PROVIDER=sqlite

# SQLite is the default local/development option
SQLITE_DATABASE_URL=file:./dev.db

# Optional PostgreSQL connection string when DATABASE_PROVIDER=postgresql
# Database provider is selected before the app boots, so it is not part of the in-app setup flow.
POSTGRES_DATABASE_URL=postgresql://ticketera:ticketera_local_password@localhost:5432/ticketera?schema=public

# Safety switch: keep false in normal production runs.
# Set true only for controlled first boot / migration windows.
RUN_DB_PUSH_ON_START=false

# Optional manual bootstrap values for the CLI bootstrap utility.
# The default startup flow now uses the in-app /setup first-run experience instead.
AUTH_BOOTSTRAP_ADMIN_EMAIL=admin@local
# Leave blank to auto-generate and print a temporary password once during bootstrap.
AUTH_BOOTSTRAP_ADMIN_PASSWORD=
AUTH_BOOTSTRAP_ADMIN_FIRST_NAME=System
AUTH_BOOTSTRAP_ADMIN_LAST_NAME=Administrator
AUTH_BOOTSTRAP_ADMIN_EMPLOYEE_ID=ADMIN-0001

# Session configuration
AUTH_SESSION_TTL_HOURS=12

# Login lockout protection
AUTH_MAX_FAILED_LOGIN_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15
